src/protocol/tools/ranger.jsonl
src/protocol/tools/ranger_phase1.json
src/protocol/tools/newnode.jsonl
src/protocol/tools/newnode_aoc.jsonl
src/protocol/tools/newnode_phase1.json
src/protocol/tools/bard_login.jsonl

